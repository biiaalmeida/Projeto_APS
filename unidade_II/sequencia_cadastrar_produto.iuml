@startuml "Cadastrar Produto"

hide footbox
skinparam sequenceMessageAlign center
skinparam participantStyle rectangle

actor "Administrador" as Admin

participant "InterfaceCadastroProduto" as Tela
participant "ProdutoController" as Controller
participant "ProdutoService" as Service
participant "AdministradorRepository" as AdminRepo
participant "PromocaoRepository" as PromocaoRepo
participant "ProdutoRepository" as ProdutoRepo
participant "Produto" as Produto

Admin -> Tela: 1: informarDadosProduto(nome, categoria, marca,\npreco, descricao, imagemUrl, administradorId, promocaoId)
activate Tela

Tela -> Tela: 1.1: validarFormulario(nome, marca, categoria,\npreco, descricao, administradorId)

alt Dados inválidos
    Tela --> Admin: 1.2: exibirErro("Preencha todos os campos obrigatórios")
    deactivate Tela

else Dados válidos
    Tela -> Controller: 1.2: cadastrar(request: ProdutoRequest)
    activate Controller

    create Produto
    Controller -> Produto: 1.2.1: <<create>>
    activate Produto

    Controller -> Service: 1.2.2: cadastrar(produto, administradorId, promocaoId)
    activate Service

    Service -> AdminRepo: 1.2.2.1: findById(administradorId)
    activate AdminRepo
    AdminRepo --> Service: administrador
    deactivate AdminRepo

    Service -> Produto: 1.2.2.2: setAdministrador(administrador)

    opt promocaoId informado
        Service -> PromocaoRepo: 1.2.2.3: findById(promocaoId)
        activate PromocaoRepo
        PromocaoRepo --> Service: promocao
        deactivate PromocaoRepo

        Service -> Produto: 1.2.2.4: setPromocao(promocao)
    end

    Service -> ProdutoRepo: 1.2.3: save(produto)
    activate ProdutoRepo
    ProdutoRepo --> Service: produtoSalvo
    deactivate ProdutoRepo

    Service --> Controller: produtoSalvo
    deactivate Service

    Controller --> Tela: produtoSalvo
    deactivate Produto
    deactivate Controller

    Tela --> Admin: 1.3: exibirMensagem("Produto cadastrado com sucesso")
    deactivate Tela
end

@enduml